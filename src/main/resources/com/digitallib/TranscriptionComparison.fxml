<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.digitallib.TranscriptionComparisonController"
            prefWidth="1200" prefHeight="750">
    <top>
        <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 8; -fx-background-color: #f5f5f5;">
            <Label text="Comparacao de Transcricoes —" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
            <Label fx:id="titleLabel" style="-fx-font-size: 14;"/>
        </HBox>
    </top>
    <center>
        <ScrollPane fx:id="horizontalScroll" fitToHeight="true" fitToWidth="true" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER">
            <HBox fx:id="panelsBox" spacing="0" HBox.hgrow="ALWAYS"/>
        </ScrollPane>
    </center>
    <bottom>
        <HBox spacing="16" alignment="CENTER_LEFT"
              style="-fx-padding: 6 12; -fx-background-color: #f0f0f0; -fx-border-color: #d0d0d0; -fx-border-width: 1 0 0 0;">
            <Label text="Legenda:" style="-fx-font-weight: bold; -fx-font-size: 11;"/>
            <!-- Yellow swatch -->
            <HBox spacing="5" alignment="CENTER_LEFT">
                <Region prefWidth="18" prefHeight="14"
                        style="-fx-background-color: #fff3cd; -fx-border-color: #aaa; -fx-border-width: 1; -fx-background-radius: 2; -fx-border-radius: 2;"/>
                <Label text="Texto diferente entre testemunhos" style="-fx-font-size: 11;"/>
            </HBox>
            <!-- Red swatch -->
            <HBox spacing="5" alignment="CENTER_LEFT">
                <Region prefWidth="18" prefHeight="14"
                        style="-fx-background-color: #ffcccc; -fx-border-color: #aaa; -fx-border-width: 1; -fx-background-radius: 2; -fx-border-radius: 2;"/>
                <Label text="Bloco ausente em algum testemunho" style="-fx-font-size: 11;"/>
            </HBox>
        </HBox>
    </bottom>
</BorderPane>
