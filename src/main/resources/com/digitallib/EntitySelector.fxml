<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<DialogPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.digitallib.EntitySelectorController"
            prefHeight="400.0" prefWidth="500.0">

    <content>
        <VBox spacing="10">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
            <Label text="Selecione:" fx:id="headerLabel"/>
            <ListView fx:id="entityListView" VBox.vgrow="ALWAYS"/>
            <HBox spacing="10" alignment="CENTER">
                <Button text="Criar Novo" onAction="#handleCreate"/>
                <Button text="Editar" onAction="#handleEdit"/>
                <Button text="Remover" onAction="#handleRemove"/>
            </HBox>
        </VBox>
    </content>

    <buttonTypes>
        <ButtonType fx:constant="OK"/>
        <ButtonType fx:constant="CANCEL"/>
    </buttonTypes>

</DialogPane>
