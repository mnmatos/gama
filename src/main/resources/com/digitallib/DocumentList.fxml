<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.digitallib.DocumentListController"
            prefHeight="800.0" prefWidth="1200.0">

    <top>
        <VBox>
            <MenuBar>
                <Menu text="Arquivo">
                    <MenuItem text="Gerenciar projetos" onAction="#handleProjectManager"/>
                    <SeparatorMenuItem />
                    <MenuItem text="Adicionar monotestemunhal" onAction="#handleAddMono"/>
                    <MenuItem text="Adicionar politestemunhal" onAction="#handleAddPoli"/>
                </Menu>
                <Menu text="Exportar">
                    <MenuItem text="Exportar Inventário" onAction="#handleExportInventory"/>
                    <MenuItem text="Exportar Ficha-catálogo" onAction="#handleExportCatalog"/>
                </Menu>
                <Menu text="Ferramentas">
                    <MenuItem text="Configurações de Transcrição…" onAction="#handleLlmSettings"/>
                    <MenuItem text="Reparar documentos com falha…" onAction="#handleRepairFailedDocs"/>
                </Menu>
                <Menu text="Ajuda">
                    <MenuItem text="Manual do Utilizador" onAction="#handleHelp"/>
                </Menu>
            </MenuBar>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <padding>
                    <Insets top="10" left="20" bottom="5"/>
                </padding>
                <Label text="Projeto:" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Label fx:id="projectNameLabel" style="-fx-font-size: 18px;"/>
            </HBox>

            <TitledPane text="Filtros" collapsible="false">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>

                    <Label text="Testemunho"/>
                    <ComboBox fx:id="testemunhoFilter" prefWidth="150" onAction="#handleRefresh"/>

                    <Label text="Série"/>
                    <ComboBox fx:id="classeFilter" prefWidth="200" onAction="#handleRefresh"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Label text="Pesquisar (código ou título)"/>
                    <TextField fx:id="filtroCodigo" prefWidth="200" promptText="código ou título…"/>
                </HBox>
            </TitledPane>

            <!-- Warning banner — hidden until the startup scan finds failures -->
            <HBox fx:id="failureBanner" visible="false" managed="false"
                  alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color: #fff3cd; -fx-border-color: #ffc107; -fx-border-width: 0 0 1 0;">
                <padding>
                    <Insets top="8" right="12" bottom="8" left="12"/>
                </padding>
                <Label text="⚠" style="-fx-font-size: 16px; -fx-text-fill: #856404;"/>
                <Label fx:id="failureBannerLabel"
                       style="-fx-text-fill: #856404; -fx-font-weight: bold;"
                       wrapText="true"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Reparar documentos…" onAction="#handleRepairFailedDocs"
                        style="-fx-background-color: #ffc107; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="tabelaPoemas" fixedCellSize="65.0">
            <columns>
                <TableColumn fx:id="colTradicao" text="Tradição"/>
                <TableColumn fx:id="colCodigo" text="Código"/>
                <TableColumn fx:id="colTitulo" text="Título"/>
                <TableColumn fx:id="colSerie" text="Série"/>
                <TableColumn fx:id="colEncontradoEm" text="Encontrado em"/>
                <TableColumn fx:id="colAcoes" text="Ações"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </center>

    <bottom>
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>

            <Label fx:id="numDocField" text="Número de documentos: 0"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="addButton" text="Adicionar" onAction="#handleAddMono"/>
        </HBox>
    </bottom>

</BorderPane>
